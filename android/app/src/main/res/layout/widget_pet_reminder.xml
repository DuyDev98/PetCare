<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <ImageView
        android:id="@+id/widget_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_bell_reminder"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true" />

    <TextView
        android:id="@+id/widget_pet_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_toEndOf="@id/widget_icon"
        android:text="Tên thú cưng"
        android:textColor="#E07B2B"
        android:textStyle="bold"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/widget_reminder_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_pet_name"
        android:layout_marginTop="8dp"
        android:text="Nội dung nhắc nhở"
        android:textColor="#424242"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/widget_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_reminder_title"
        android:layout_marginTop="4dp"
        android:text="Thời gian"
        android:textColor="#E07B2B"
        android:textSize="12sp" />

</RelativeLayout>
